{
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Bash(db-cli *)",
      "Bash(ge-doubao-cli *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(git *)",
      "Bash(gh *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$CLAUDE_ENV_FILE\" ] && [ -n \"$CLAUDE_PROJECT_DIR\" ] && printf 'export PATH=\"%s/bin:$PATH\"\\n' \"$CLAUDE_PROJECT_DIR\" >> \"$CLAUDE_ENV_FILE\""
          }
        ]
      }
    ]
  }
}
